?sweep
wt_distance <- function (data, center, cov, weight) {
if (is.vector(data))
data = matrix(x, ncol = length(data))
else data = as.matrix(data)
data <- sweep(data, 2, center)
cov <- weight %*% solve(cov)
retval <- diag(data %*% cov %*% t(data))
retval
}
