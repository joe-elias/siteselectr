log_to_prop <- function(rast, cls, extent, shell){
terra::crop(rast, extent)
obj<-rast %in% cls
obj_proj<-project(obj, shell)
return(obj_proj)
}
t <- siteselectr::log_to_prop(rast = soil_data,
cls = 18, extent = sample_extent, shell = shell_x)
