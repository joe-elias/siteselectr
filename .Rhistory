vis_cor<-function(values){
cor_val<-cor(values)
palette <- colorRampPalette(c("#56B4E9", "white", "orangered"))(100)
heatmap(cor_val,
col = palette,
symm = TRUE, # Ensures symmetry for correlation matrix
margins = c(8, 8))
return(cor_val)
}
