f1 <- sample_ext(x=50, y=30, 300000, crs = 4326)
f2 <- sample_ext(x=40, y=25, 300000, crs = 4326)
f3 <- sample_ext(x=40, y=40, 300000, crs = 4326)
f4 <- sample_ext(x=25, y=35, 300000, crs = 4326)
f5 <- sample_ext(x=45, y=50, 300000, crs = 4326)
f6 <- sample_ext(x=30, y=40, 300000, crs = 4326)
f7 <- sample_ext(x=35, y=50, 300000, crs = 4326)
f8 <- sample_ext(x=25, y=45, 300000, crs = 4326)
fil <- rbind(f1, f2, f3, f4, f5,
f6, f7, f8)
plot(r_stack[[1]]) ; lines(ext, col='red', lwd=3); lines(fil, col='red', lwd = 2)
fil_after<-site_select_fil(long=10, lat=15, num=12, stack=r_stack,
filter = fil, type = "after")
70*70
# simulate data
var_list <- list()
n <- 7
ext <- sampling_extent<-siteselectr::sample_ext(x=40, y=40, 2500000, crs=4326)
for (i in 1:n){
var<-terra::rast(matrix(rnorm(4900, mean=0, sd=5),
nrow=70, ncol=70), crs="EPSG:4326")
var_list <- c(var_list, var)
}
r_stack <- rast_stack(var_list, extent = ext)
names(r_stack) <- c("l1", "l2", "l3", "l4",
"l5", "l6", "l7")
# simulate polygons to mask rasters (our filter)
