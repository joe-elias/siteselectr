weighted_layer = c(1, 3), magnitude = 0.5)
print(weighted_cells)
weighted_xy <- terra::xyFromCell(r_stack[[1]], weighted_cells)
plot(r_stack[[3]]) ; points(weighted_xy, col='red', pch=19)
